# ============================================================================
# AstralInsight BA - Enterprise Backend Environment Configuration
# ============================================================================
# Copy this file to .env and fill in with your actual credentials
# ============================================================================

# ============================================================================
# DATABASE
# ============================================================================
DATABASE_URL="postgresql://postgres:password@localhost:5432/astral_insight_ba"
REDIS_URL="redis://localhost:6379"

# ============================================================================
# APPLICATION
# ============================================================================
NODE_ENV="development"
PORT=3001
API_BASE_URL="http://localhost:3001"
FRONTEND_URL="http://localhost:5174"

# ============================================================================
# JWT AUTHENTICATION
# ============================================================================
JWT_SECRET="your-super-secure-jwt-secret-key-here-change-in-production"
JWT_EXPIRES_IN="7d"

# ============================================================================
# SHOPIFY INTEGRATION
# ============================================================================
SHOPIFY_STORE_DOMAIN="your-store-name.myshopify.com"
SHOPIFY_API_KEY="your_shopify_api_key_here"
SHOPIFY_API_SECRET="your_shopify_api_secret_here"
SHOPIFY_ADMIN_ACCESS_TOKEN="your_shopify_admin_access_token_here"
SHOPIFY_API_VERSION="2024-01"

# ============================================================================
# STRIPE INTEGRATION
# ============================================================================
STRIPE_SECRET_KEY="sk_test_your_stripe_secret_here"
STRIPE_PUBLISHABLE_KEY="pk_test_your_stripe_publishable_key_here"
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_secret_here"

# ============================================================================
# GOOGLE ANALYTICS INTEGRATION
# ============================================================================
GOOGLE_ANALYTICS_PROPERTY_ID="123456789"
GOOGLE_CLIENT_EMAIL="your-service-account@your-project.iam.gserviceaccount.com"
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYourPrivateKeyHere\n-----END PRIVATE KEY-----"

# ============================================================================
# OPENAI (AI COPILOT)
# ============================================================================
OPENAI_API_KEY="sk-your-openai-api-key-here"
OPENAI_MODEL="gpt-4"
OPENAI_ORG_ID="org-your-org-id"

# ============================================================================
# PYTHON FORECASTING MICROSERVICE
# ============================================================================
PYTHON_API_URL="http://localhost:8000"
PYTHON_API_KEY="your-python-api-key"

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL="debug"
LOG_FORMAT="pretty"

# ============================================================================
# SECURITY
# ============================================================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
CORS_ORIGIN="http://localhost:5174,http://localhost:3000"

# ============================================================================
# OPTIONAL: EMAIL/NOTIFICATIONS
# ============================================================================
# SENDGRID_API_KEY="your_sendgrid_key_here"
# TWILIO_ACCOUNT_SID="your_twilio_sid"
# TWILIO_AUTH_TOKEN="your_twilio_token"

# ============================================================================
# OPTIONAL: MONITORING & TRACING
# ============================================================================
# SENTRY_DSN="your_sentry_dsn_here"
# NEW_RELIC_LICENSE_KEY="your_new_relic_key"
