{
  "name": "astral-insight-ba-backend",
  "version": "2.0.0",
  "description": "Enterprise-grade AI predictive analytics platform backend - PostgreSQL + Prisma + Express + Socket.io + Redis",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "tsx prisma/seed.ts",
    "prisma:studio": "prisma studio",
    "seed": "npm run prisma:seed",
    "setup": "npm install && npx prisma migrate dev && npm run seed"
  },
  "dependencies": {
    "@prisma/client": "^5.8.0",
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "axios": "^1.6.2",
    "@faker-js/faker": "^8.3.1",
    "socket.io": "^4.6.1",
    "socket.io-client": "^4.6.1",
    "redis": "^4.6.10",
    "jsonwebtoken": "^9.1.2",
    "bcryptjs": "^2.4.3",
    "joi": "^17.11.0",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.0",
    "openai": "^4.24.1",
    "shopify-api": "^10.3.0",
    "stripe": "^14.1.0",
    "google-analytics-data": "^11.2.0",
    "google-auth-library": "^9.6.1",
    "node-cache": "^5.1.2",
    "pino": "^8.17.2",
    "pino-pretty": "^10.3.1",
    "uuid": "^9.0.1",
    "decimal.js": "^10.4.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/bcryptjs": "^2.4.6",
    "typescript": "^5.3.3",
    "prisma": "^5.8.0",
    "tsx": "^4.7.0",
    "ts-node": "^10.9.2",
    "@types/uuid": "^9.0.7"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
